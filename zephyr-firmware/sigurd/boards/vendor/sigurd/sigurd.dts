/dts-v1/;
#include <st/u5/stm32u575Xg.dtsi>
#include <st/u5/stm32u575rgtx-pinctrl.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
	model = "Sigurd board";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,canbus = &fdcan1;
		zephyr,console = &uart4;
		zephyr,shell-uart = &uart4;
	};

	aliases {
		xadc1 = &ext_adc1;
		fdcan1 = &fdcan1;
		spimisoready = &spi1_miso_pa6;
	};


    leds {
        compatible = "gpio-leds";
        
        led0: led_0 {
			gpios = <&gpioa 15 GPIO_ACTIVE_HIGH>;
			label = "TX LED";
		};


        chipselect1: chipselect1 {
			gpios = <&gpioa 4 GPIO_ACTIVE_LOW>;
			label = "chip select";
		};

		led1: led_1 {
			gpios = <&gpiob 3 GPIO_ACTIVE_HIGH>;
			label = "RX LED";
		};

    };

	buttons {
		compatible = "gpio-keys";
        spiadcready: spiadcready {
			gpios = <&gpiob 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>;
			label = "spi adc ready";
			zephyr,code = <INPUT_KEY_0>;
		};
	};

	rgbleds {
        compatible = "gpio-leds";
        
        g: green_led {
			gpios = <&gpiob 15 GPIO_ACTIVE_HIGH>;
			label = "green RGB LED";
		};

		r: red_led {
			gpios = <&gpiob 13 GPIO_ACTIVE_HIGH>;
			label = "green RGB LED";
		};

		

    };


};

&clk_hse {
    clock-frequency = <DT_FREQ_M(24)>; /* your crystal MHz */
    status = "okay";
};

&pll1 {
	div-m = <2>;
	mul-n = <30>;
	div-q = <4>;
	div-r = <4>;
	clocks = <&clk_hse>;
	status = "okay";
};

&rcc {
	clocks = <&pll1>;
	clock-frequency = <DT_FREQ_M(90)>;
	ahb-prescaler = <1>;
	apb1-prescaler = <1>;
	apb2-prescaler = <1>;
	apb3-prescaler = <1>;
};

&fdcan1 {
	clocks = <&rcc STM32_CLOCK_BUS_APB1_2 0x00000200>,
		 <&rcc STM32_SRC_PLL1_Q FDCAN1_SEL(1)>;
	pinctrl-0 = <&fdcan1_rx_pb8 &fdcan1_tx_pb9>;
	pinctrl-names = "default";
	status = "okay";
};

&spi1 {
    // compatible = "zephyr,spi-emul-controller";
    // compatible = "spi-device"
    status = "okay";
	pinctrl-0 = <&spi1_sck_pa5 &spi1_miso_pa6 &spi1_mosi_pa7>;
	pinctrl-names = "default";
    // cs-gpios = <&gpioa 4 GPIO_ACTIVE_LOW>;
	clock-frequency = <10000000>;

    ext_adc1: ad4111@0 {
		compatible = "analog,ad4111";
        status = "okay";
        reg = <0>;
        //spi-max-frequency = <100000>;
        spi-max-frequency = <10000000>;
    };

};

&uart4 {
    pinctrl-0 = <&uart4_tx_pa0 &uart4_rx_pa1>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};


&spi1_sck_pa5 {
	/delete-property/ bias-pull-down;
	bias-pull-up;
};